<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
        <!-- 日志输出格式：时间、日志级别、线程名、类名和方法名、日志消息 -->

        <pattern>{"timestamp":"%d{"yyyy-MM-dd'T'HH:mm:ss.SSSX"}","log_level":"%p","caller":"%c{40}.%M","invoke_id":"%X{invoke_id}"%X{LogChainInfo}} %replace(%m){'\n','%n'}%n</pattern>

        <!--<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>-->
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>

